{
  "name": "epsg-index-2",
  "version": "1.0.5",
  "main": "./all.js",
  "module": "./all.js",
  "type": "module",
  "exports": {
    ".": "./all.js",
    "./*": "./codes/*.js"
  },
  "homepage": "https://github.com/DerZade/epsg-index-2#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DerZade/epsg-index-2.git"
  },
  "bugs": {
    "url": "https://github.com/derzade/epsg-index-2/issues"
  },
  "keywords": [
    "epsg",
    "proj4",
    "wkt",
    "index"
  ],
  "author": "Jonas Schade <derzade@gmail.com>",
  "license": "MIT",
  "description": "An up-to-date* list of all known EPSGs definitions as well as the nadgrid files, which are referenced by at least one EPSG definition.",
  "files": [
    "codes",
    "grids",
    "all.d.ts",
    "all.js",
    "index.d.ts"
  ],
  "devDependencies": {
    "@sinclair/typebox": "^0.34.35",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.9.3",
    "@types/proj4": "^2.5.6",
    "adm-zip": "^0.5.17",
    "prettier": "^3.8.4",
    "proj4": "^2.20.9",
    "tsx": "^4.20.3",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "update-index": "tsx tools/update-index.ts",
    "check-grids": "tsx tools/check-grids.ts",
    "build": "tsx tools/build.ts",
    "prepublishOnly": "npm run build",
    "format": "prettier --write .",
    "test:unit": "vitest --run"
  }
}
